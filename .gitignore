# ── Azure Functions ───────────────────────────────────────────────────────────
bin/
**/bin/
obj/
csx/
.vs/
edge/
Publish/
local.settings.json          # contains secrets / connection strings
.python_packages/            # remote-build output

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
.env
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# Type checker / linter caches
.mypy_cache/
.dmypy.json
.ruff_cache/
.pyright/

# Test / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
/TestResults/

# Jupyter
.ipynb_checkpoints/

# ── spaCy models (large; install via requirements.txt wheel URL) ──────────────
# Uncomment if you ever do `python -m spacy download` locally:
# en_core_web_*/

# ── Bicep / Azure CLI ─────────────────────────────────────────────────────────
# Compiled ARM templates generated by bicep build
*.json.bak
infra/*.json                 # prevent accidental arm-template commits
!host.json                   # host.json IS part of the repo
!local.settings.json.example # keep the example template if you add one

# Azure CLI token cache (shouldn't be here, but just in case)
.azure/

# ── Secrets / credentials ─────────────────────────────────────────────────────
*.pem
*.key
*.pfx
*.p12
secrets/
.secrets
appsettings.json
appsettings.*.json

# ── Azurite (local storage emulator) ─────────────────────────────────────────
__blobstorage__/
__queuestorage__/
__azurite_db*__.json

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/settings.json        # personal editor settings
.vscode/launch.json          # personal debug configs
# Keep: .vscode/extensions.json (recommended extensions for the team)

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Misc ──────────────────────────────────────────────────────────────────────
*.user
*.suo
*.Cache
*.log
node_modules/
packages/